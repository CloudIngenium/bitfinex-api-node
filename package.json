{
  "name": "@jcbit/bitfinex-api-node",
  "version": "9.0.0",
  "description": "Node reference library for Bitfinex API - TypeScript Modernized Fork",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "npm run build && npm run lint && npm run unit",
    "test:watch": "npm run unit -- --watch",
    "unit": "NODE_ENV=test mocha -b --recursive --exit",
    "coverage": "c8 --reporter=text --reporter=lcov npm run unit",
    "coverage:check": "c8 check-coverage --lines 90 --functions 90 --branches 85",
    "prepare": "husky || true",
    "start": "node examples/rest2/ticker.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudIngenium/bitfinex-api-node.git"
  },
  "keywords": [
    "bitfinex",
    "bitcoin",
    "BTC",
    "cryptocurrency",
    "trading",
    "api",
    "websocket",
    "rest",
    "typescript"
  ],
  "contributors": [
    "JC <jcbauza@users.noreply.github.com> (https://github.com/jcbauza)",
    "Ezequiel Wernicke <ezequiel.wernicke@bitfinex.com> (https://www.bitfinex.com)",
    "Josh Rossi <josh@bitfinex.com> (https://www.bitfinex.com)",
    "Cris Mihalache <cris.m@bitfinex.com> (https://www.bitfinex.com)",
    "Robert Kowalski <robert@bitfinex.com> (https://www.bitfinex.com)",
    "Simone Poggi <simone@bitfinex.com> (https://www.bitfinex.com)",
    "Paolo Ardoino <paolo@bitfinex.com> (https://www.bitfinex.com)",
    "Abhishek Shrestha <abhishek.shrestha@bitfinex.com> (https://www.bitfinex.com)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CloudIngenium/bitfinex-api-node/issues"
  },
  "homepage": "https://github.com/CloudIngenium/bitfinex-api-node#readme",
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.0",
    "bfx-api-mock-srv": "^2.0.0",
    "c8": "^10.1.0",
    "dotenv": "^17.2.1",
    "mocha": "^11.7.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@jcbit/bfx-api-node-rest": "github:CloudIngenium/bfx-api-node-rest#v9.1.0",
    "@cloudingenium/bfx-api-node-models": "*",
    "bfx-api-node-util": "^1.0.12",
    "bfx-api-node-ws1": "^1.0.4",
    "bignumber.js": "^9.3.1",
    "debug": "^4.4.1",
    "lossless-json": "^4.1.1",
    "promise-throttle": "^1.1.2",
    "ws": "^8.18.3"
  },
  "publishConfig": {
    "@jcbit:registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "overrides": {
    "bfx-api-node-ws1": {
      "debug": "^4.4.1",
      "ws": "^8.18.3"
    },
    "serialize-javascript": ">=7.0.5"
  }
}
